# az-scout-plugin-bdd-sku – Terraform Configuration Example
# ==========================================================
# Copy this file to terraform.tfvars and fill in your values.

# Azure Subscription (REQUIRED)
subscription_id = "your-subscription-id-here"

# Resource Naming and Location
resource_group_name = "bdd-sku-RG"
location            = "germanywestcentral"
prefix              = "bdd-sku"
environment         = "production"

# PostgreSQL
postgres_admin_user     = "azscout"
postgres_admin_password = "CHANGE-ME-strong-password-123!"
postgres_db_name        = "azscout"
postgres_sku            = "B_Standard_B1ms"
postgres_storage_mb     = 32768

# Ingestion Jobs
max_pricing_items  = "-1"         # -1 = unlimited
cron_expression    = "0 2 * * *"  # Daily at 02:00 UTC
sku_mapper_cron    = "0 4 * * *"  # Daily at 04:00 UTC (after ingestion)
log_level          = "INFO"

# API Container App
api_cpu          = 0.5
api_memory       = "1Gi"
api_min_replicas = 1
api_max_replicas = 10
api_port         = 8000

# ---------------------------------------------------------------
# Example: Development environment (lower cost)
# ---------------------------------------------------------------
# resource_group_name     = "bdd-sku-dev-RG"
# prefix                  = "bdd-sku-dev"
# environment             = "development"
# postgres_sku            = "B_Standard_B1ms"
# postgres_storage_mb     = 32768
# max_pricing_items       = "1000"
# log_level               = "DEBUG"
# api_cpu                 = 0.25
# api_memory              = "0.5Gi"
# api_min_replicas        = 1
# api_max_replicas        = 3
